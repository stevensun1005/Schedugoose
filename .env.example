# Schedugoose environment configuration.
# Copy to `.env` and fill in. The OR core needs NONE of these to run.

# University of Waterloo Open Data API v3 key.
# https://openapi.data.uwaterloo.ca/  -- when unset, Schedugoose uses bundled mock data.
UW_API_KEY=

# Anthropic key for the LLM semantic + explanation layers.
# When unset, Schedugoose falls back to a deterministic rule-based parser.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Redis URL for multi-turn session memory + API response caching.
# When unset, an in-process cache is used instead.
REDIS_URL=

# Default term to plan for (UW term code, e.g. 1255 = Spring 2025).
DEFAULT_TERM=1255
