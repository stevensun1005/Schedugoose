# Schedugoose environment configuration.
# Copy to `.env` and fill in. The OR core needs NONE of these to run.

# University of Waterloo Open Data API v3 key.
# https://openapi.data.uwaterloo.ca/  -- when unset, Schedugoose uses bundled mock data.
UW_API_KEY=

# --------------------------------------------------------------------------- #
# LLM — FREE tier (recommended, no credit card)
# --------------------------------------------------------------------------- #
# Groq: https://console.groq.com/keys  (~1,000 req/day, fast, OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# The running app requires an LLM by default (every message goes through it).
# Set to 0 only for offline demos / the deterministic test + eval harness.
# SCHEDUGOOSE_REQUIRE_LLM=1

# OpenRouter free models (alternative): https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Legacy alias: same Groq key also works via OPENAI_* (optional)
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Paid (optional, not needed for development)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Embeddings for MongoDB RAG only (optional; local hash fallback if unset)
# OPENAI_EMBED_MODEL=text-embedding-3-small

# MongoDB Atlas Vector Search for career→course RAG (optional).
# When unset, cosine similarity over the bundled knowledge base is used.
MONGODB_URI=
MONGODB_DB=schedugoose
MONGODB_KB_COLLECTION=career_kb
MONGODB_VECTOR_INDEX=career_vector_index

# Redis URL for multi-turn session memory + LangGraph checkpointing.
REDIS_URL=

DEFAULT_TERM=1255

# Live section times: swap mock meeting times for real /ClassSchedules data on
# published terms (bounded + cached). Set to 0 to disable.
# SCHEDUGOOSE_LIVE_SECTIONS=1

# Where file-backed sessions live when REDIS_URL is unset (survive restarts).
# SESSION_DIR=data/sessions
